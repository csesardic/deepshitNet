#!/bin/sh
set -e

IDENTITY_FILE="/var/lib/deepshit/reticulum/identity.id"

echo "=== DeepShitNet Status ==="

echo ""
if python3 -c "import RNS" >/dev/null 2>&1; then
    echo "Reticulum: Installed"
else
    echo "Reticulum: Not installed"
fi

if [ -f "$IDENTITY_FILE" ]; then
    echo "Node identity: Present at $IDENTITY_FILE"
else
    echo "Node identity: Not generated"
fi

if command -v systemctl >/dev/null 2>&1; then
    if systemctl is-active --quiet deepshit-reticulum.service; then
        echo "Reticulum service: Active"
    else
        echo "Reticulum service: Inactive"
    fi
fi

echo ""
echo "Run 'steve' for a quick check."
